{
  // ── TEMA ──────────────────────────────────
  "workbench.colorTheme": "Minimal Kiwi",
  "workbench.iconTheme": "symbols",

  // ── CSS ─────────────────────────
  "vscode_custom_css.imports": [
    "file:////home/vinciusgoncalves/.config/vscode/vscode-custom.css",
  ],
  "vscode_custom_css.policy": true,

  // ── VISUAL ──────────────────────────
  "workbench.startupEditor": "none",
  "workbench.editor.showTabs": "none",
  "workbench.editor.labelFormat": "short",
  "workbench.activityBar.location": "hidden",
  "workbench.layoutControl.enabled": false,
  "workbench.editor.empty.hint": "hidden",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.sideBar.location": "right",
  "workbench.tree.enableStickyScroll": false,

  // Title bar
  "window.titleBarStyle": "custom",
  "window.customTitleBarVisibility": "auto",
  "window.commandCenter": false,
  "window.menuBarVisibility": "toggle",
  "window.title": "${activeEditorShort}",

  // Breadcrumbs
  "breadcrumbs.enabled": false,

  // ── EDITOR ────────────────────────────────
  "editor.fontFamily": "'JetBrainsMono Nerd Font', monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.8,
  "editor.lineNumbers": "relative",
  "editor.cursorStyle": "block",
  "editor.cursorBlinking": "solid",
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": false,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.verticalScrollbarSize": 0,
  "editor.renderLineHighlight": "gutter",
  "editor.showFoldingControls": "never",
  "editor.matchBrackets": "never",
  "editor.guides.bracketPairs": "active",
  "editor.glyphMargin": false,
  "editor.semanticHighlighting.enabled": false,
  "editor.suggestOnTriggerCharacters": true,
  "editor.largeFileOptimizations": true,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.padding.top": 4,

  // ── TERMINAL ──────────────────────────────
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.tabs.enabled": false,

  // ── EXPLORER ──────────────────────────────
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "files.exclude": {
    "dist": true,
    ".circleci": true,
    ".github": true,
    "node_modules": true,
  },

  // ── COPILOT ───────────────────────────────
  "github.copilot.editor.enableAutoCompletions": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.renameSuggestions.triggerAutomatically": false,
  "github.copilot.advanced": {},

  // ── GIT ───────────────────────────────────
  "git.confirmSync": false,
  "git.suggestSmartCommit": false,
  "git.ignoreRebaseWarning": true,
  "diffEditor.ignoreTrimWhitespace": false,

  // ── GITLENS ───────────────────────────────
  "gitlens.currentLine.enabled": true,
  "gitlens.hovers.currentLine.details": true,
  "gitlens.hovers.currentLine.over": "annotation",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",

  // ── NEOVIM ────────────────────────────────
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1,
  },

  // ── DEBUG ─────────────────────────────────
  "debug.inlineValues": "off",
  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#1a1a1a",
    "titleBar.inactiveBackground": "#1a1a1a",
    "titleBar.activeForeground": "#c8c8c8",
    "titleBar.inactiveForeground": "#666666",
    "titleBar.border": "#00000000",
    "editor.background": "#1a1a1a",
    "editorGroupHeader.tabsBackground": "#1a1a1a",
    "editorGroupHeader.noTabsBackground": "#1a1a1a",
    "editorGroupHeader.tabsBorder": "#00000000",
    "editorGroupHeader.border": "#00000000",
    "editorGroup.border": "#00000000",
    "editorGroup.emptyBackground": "#1a1a1a",
    "sideBar.background": "#1a1a1a",
    "sideBar.border": "#00000000",
    "panel.background": "#1a1a1a",
    "panel.border": "#00000000",
    "activityBar.border": "#00000000",
    "statusBar.border": "#00000000"
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features",
  },
  "git.autofetch": true,
  "explorer.confirmPasteNative": false,
  "docker.extension.enableComposeLanguageServer": false,
  "workbench.statusBar.visible": false,
}
